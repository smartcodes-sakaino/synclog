# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3000/api/auth/callback

# このメールアドレスのGoogleアカウントのみログインを許可する
ALLOWED_LOGIN_EMAIL=t.sakaino@tcdigital.jp

# Supabase
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# トークン・セッション暗号化用の鍵(32バイトのランダム文字列を生成して設定する)
TOKEN_ENCRYPTION_KEY=
SESSION_SECRET=

# Google Gemini API
GEMINI_API_KEY=

# 日報自動生成の定時実行(Cron)からの呼び出し検証用シークレット
CRON_SECRET=

# Replit Scheduled Deploymentからcronスクリプトを実行する際に使う、公開後のアプリのURL
# (例: https://synclog.your-team.replit.app)
APP_BASE_URL=
