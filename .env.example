# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# このメールアドレスのGoogleアカウントのみログインを許可する
ALLOWED_LOGIN_EMAIL=t.sakaino@tcdigital.jp

# 公開後のアプリのURL(末尾にスラッシュなし)。ログイン用/アカウント連携用の
# OAuthコールバックURLの組み立てに使う
# (例: https://synclog.vercel.app / ローカルなら http://localhost:3000)
APP_BASE_URL=http://localhost:3000

# PostgreSQL接続文字列(Replit PostgreSQLの接続文字列をそのまま使う。DBはReplit側に残したまま利用する)
DATABASE_URL=

# トークン・セッション暗号化用の鍵(32バイトのランダム文字列を生成して設定する)
TOKEN_ENCRYPTION_KEY=
SESSION_SECRET=

# Google Gemini API
GOOGLE_AI_API_KEY=

# 日報自動生成の定時実行(Vercel Cron)からの呼び出し検証用シークレット
CRON_SECRET=
